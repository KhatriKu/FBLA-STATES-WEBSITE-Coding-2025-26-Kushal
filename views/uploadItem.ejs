    <script>
        // Auth wall
        (function() {
            const t = localStorage.getItem('userToken');
            if (!t) { window.location.href = '/login?next=/uploadItem'; return; }
            try {
                const p = JSON.parse(atob(t.split('.')[1]));
                if (p.exp && Date.now() / 1000 > p.exp) {
                    localStorage.removeItem('userToken');
                    window.location.href = '/login?next=/uploadItem';
                    return;
                }
                // Auto-fill contact fields from token
                if (p.name)  { const el = document.getElementById('contactName');  if (el) el.value = p.name; }
                if (p.email) { const el = document.getElementById('contactEmail'); if (el) el.value = p.email; }
            } catch(e) { localStorage.removeItem('userToken'); window.location.href = '/login?next=/uploadItem'; }
        })();

        // Load categories from API
        (async function() {
            try {
                const res  = await fetch('/api/categories');
                const data = await res.json();
                if (data.success) {
                    const sel = document.getElementById('category');
                    data.categories.forEach(cat => {
                        const opt = document.createElement('option');
                        opt.value = cat.name; opt.textContent = cat.name;
                        sel.appendChild(opt);
                    });
                }
            } catch(e) {}
        })();

        // Image preview handler
        const imageInput = document.getElementById('itemImage');
        const imagePreview = document.getElementById('imagePreview');
        const previewImage = document.getElementById('previewImage');

        imageInput.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = (event) => {
                    previewImage.src = event.target.result;
                    imagePreview.style.display = 'block';
                };
                reader.readAsDataURL(file);
            }
        });

        // Drag and drop for file input
        const fileLabel = document.querySelector('.file-input-label');
        
        fileLabel.addEventListener('dragover', (e) => {
            e.preventDefault();
            fileLabel.style.background = 'rgba(0, 102, 204, 0.15)';
            fileLabel.style.borderColor = '#cc0000';
        });

        fileLabel.addEventListener('dragleave', () => {
            fileLabel.style.background = 'rgba(0, 102, 204, 0.05)';
            fileLabel.style.borderColor = '#0066cc';
        });

        fileLabel.addEventListener('drop', (e) => {
            e.preventDefault();
            fileLabel.style.background = 'rgba(0, 102, 204, 0.05)';
            fileLabel.style.borderColor = '#0066cc';
            
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                imageInput.files = files;
                const event = new Event('change', { bubbles: true });
                imageInput.dispatchEvent(event);
            }
        });

        // Form submission handler
        const uploadForm = document.getElementById('uploadForm');
        const statusMessage = document.getElementById('statusMessage');
        const loadingIndicator = document.getElementById('loadingIndicator');
        const submitBtn = document.getElementById('submitBtn');

        uploadForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            // Validate required fields
            const itemName = document.getElementById('itemName').value.trim();
            const dateFound = document.getElementById('dateFound').value;
            const location = document.getElementById('location').value.trim();
            const contactName = document.getElementById('contactName').value.trim();
            const contactNumber = document.getElementById('contactNumber').value.trim();
            const contactEmail = document.getElementById('contactEmail').value.trim();

            if (!itemName || !dateFound || !location || !contactName || !contactNumber || !contactEmail) {
                showStatus('Please fill in all required fields', 'error');
                return;
            }

            try {
                showLoading(true);

                // Create FormData object
                const formData = new FormData();
                formData.append('itemName', itemName);
                formData.append('description', document.getElementById('description').value);
                formData.append('category', document.getElementById('category').value);
                formData.append('dateFound', dateFound);
                formData.append('location', location);
                formData.append('contactName', contactName);
                formData.append('contactNumber', contactNumber);
                formData.append('contactEmail', contactEmail);

                // Pin coordinates (optional — only if user dropped a marker)
                const pinLat = document.getElementById('pinLat').value;
                const pinLng = document.getElementById('pinLng').value;
                const pinFloor = document.getElementById('pinFloor').value;
                if (pinLat && pinLng) {
                    formData.append('pinLat', pinLat);
                    formData.append('pinLng', pinLng);
                }
                if (pinFloor) {
                    formData.append('pinFloor', pinFloor);
                }

                // Add image if selected
                const imageFile = imageInput.files[0];
                if (imageFile) {
                    formData.append('itemImage', imageFile);
                }

                // Submit to server
                const response = await fetch('/api/upload', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (response.ok) {
                    showStatus('Item submitted successfully! Thank you for helping.', 'success');
                    uploadForm.reset();
                    imagePreview.style.display = 'none';
                    
                    // Redirect after 2 seconds
                    setTimeout(() => {
                        window.location.href = '/browse';
                    }, 2000);
                } else {
                    showStatus(data.message || 'Failed to submit item. Please try again.', 'error');
                }
            } catch (error) {
                console.error('Upload error:', error);
                showStatus('Error submitting item. Please check your connection and try again.', 'error');
            } finally {
                showLoading(false);
            }
        });

        function showStatus(message, type) {
            statusMessage.textContent = message;
            statusMessage.className = `status-message status-${type} show`;
            window.scrollTo(0, 0);

            setTimeout(() => {
                statusMessage.classList.remove('show');
            }, 6000);
        }

        function showLoading(show) {
            if (show) {
                loadingIndicator.classList.add('show');
                submitBtn.disabled = true;
            } else {
                loadingIndicator.classList.remove('show');
                submitBtn.disabled = false;
            }
        }

        // Navbar scroll effect
        window.addEventListener('scroll', () => {
            const navbar = document.getElementById('nav-bar');
            if (window.scrollY > 50) {
                navbar.classList.remove('transparent');
            } else {
                navbar.classList.add('transparent');
            }
        });

        // Hamburger menu toggle
        const hamburgerBtn = document.getElementById('hamburgerBtn');
        const mobileMenu = document.getElementById('mobileMenu');

        if (hamburgerBtn) {
            hamburgerBtn.addEventListener('click', () => {
                hamburgerBtn.classList.toggle('active');
                mobileMenu.classList.toggle('active');
            });

            mobileMenu.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', () => {
                    hamburgerBtn.classList.remove('active');
                    mobileMenu.classList.remove('active');
                });
            });
        }
    </script>

    <script>
    // ── TENSORFLOW MOBILENET AI CLASSIFICATION ────────────────────────────────
    // Loads MobileNet model on page open, classifies item image on demand.
    // Maps ImageNet class names → your existing Lost But Found categories.

    let mobileNetModel = null;
    let aiSuggestedCategory = null;
    let aiSuggestedName     = null;

    // ── CATEGORY MAP ──────────────────────────────────────────────────────────
    // Keys are substrings matched against MobileNet class names (lowercase).
    // Values are your exact category names from the DB.
    const CATEGORY_MAP = [
        { keywords: ['phone','cellular','mobile','iphone','smartphone','ipod'],       category: 'Electronics' },
        { keywords: ['laptop','notebook computer','computer','keyboard','mouse','remote','calculator','headphone','earphone','airpod','speaker'],  category: 'Electronics' },
        { keywords: ['backpack','bag','purse','wallet','handbag','suitcase','briefcase'], category: 'Accessories' },
        { keywords: ['watch','jewelry','necklace','bracelet','ring','sunglasses','glasses','spectacles'], category: 'Accessories' },
        { keywords: ['shoe','sneaker','boot','sandal','running shoe','loafer'],        category: 'Clothing' },
        { keywords: ['jacket','coat','shirt','jersey','sweatshirt','hoodie','hat','cap','glove','scarf','tie'], category: 'Clothing' },
        { keywords: ['book','notebook','binder','pencil','pen','ruler','scissors','folder','textbook'], category: 'Books & Supplies' },
        { keywords: ['key','umbrella','id','badge','card','bottle','mug','cup'],       category: 'Personal Items' },
        { keywords: ['ball','racket','glove','helmet','bat','bicycle','gym','dumbbell'], category: 'Sports Equipment' },
    ];

    function mapToCategory(predictions) {
        for (const pred of predictions) {
            const name = pred.className.toLowerCase();
            for (const rule of CATEGORY_MAP) {
                if (rule.keywords.some(kw => name.includes(kw))) {
                    return { category: rule.category, matchedName: pred.className, confidence: pred.probability };
                }
            }
        }
        return { category: 'Other', matchedName: predictions[0]?.className || 'Unknown item', confidence: predictions[0]?.probability || 0 };
    }

    // ── LOAD MODEL ON PAGE OPEN ───────────────────────────────────────────────
    (async function loadModel() {
        const dot  = document.getElementById('aiStatusDot');
        const text = document.getElementById('aiStatusText');
        const btn  = document.getElementById('aiScanBtn');
        try {
            mobileNetModel = await mobilenet.load({ version: 2, alpha: 1.0 });
            dot.className  = 'ready';
            text.textContent = 'AI ready';
            btn.disabled = false;
            // Enable button only if image already loaded
            if (document.getElementById('previewImage').src) btn.disabled = false;
        } catch (err) {
            dot.className  = 'error';
            text.textContent = 'AI unavailable';
            console.error('MobileNet load error:', err);
        }
    })();

    // ── RUN SCAN ──────────────────────────────────────────────────────────────
    async function runAIScan() {
        const img  = document.getElementById('previewImage');
        const btn  = document.getElementById('aiScanBtn');
        const card = document.getElementById('aiSuggestionCard');

        if (!img.src || !img.complete) {
            alert('Please upload an image first.');
            return;
        }
        if (!mobileNetModel) {
            alert('AI model is still loading, please wait a moment.');
            return;
        }

        // Scanning state
        btn.disabled = true;
        btn.innerHTML = '<i data-lucide="loader-2" style="animation:spin 1s linear infinite;display:inline-block"></i> Scanning...';
        lucide.createIcons();
        card.style.display = 'none';

        try {
            const predictions = await mobileNetModel.classify(img, 5);
            const result      = mapToCategory(predictions);

            aiSuggestedCategory = result.category;
            aiSuggestedName     = result.matchedName;

            // Populate suggestion card
            document.getElementById('aiDetectedItem').textContent =
                result.matchedName + ' (' + Math.round(result.confidence * 100) + '% confidence)';
            document.getElementById('aiDetectedCategory').innerHTML =
                'Suggested category: <strong>' + result.category + '</strong><br>'
                + 'Suggested item name: <strong>' + result.matchedName + '</strong>';
            document.getElementById('aiRawPredictions').innerHTML =
                'Also detected: ' + predictions.slice(1, 4).map(p =>
                    p.className + ' (' + Math.round(p.probability * 100) + '%)').join(', ');

            card.style.display = 'block';

        } catch (err) {
            console.error('Classification error:', err);
            alert('Scan failed. Please try again.');
        }

        btn.disabled = false;
        btn.innerHTML = '<i data-lucide="camera"></i> Scan with AI';
        lucide.createIcons();
    }

    // ── ACCEPT SUGGESTION ─────────────────────────────────────────────────────
    function acceptAISuggestion() {
        if (!aiSuggestedCategory) return;

        // Fill category dropdown
        const sel = document.getElementById('category');
        for (const opt of sel.options) {
            if (opt.value === aiSuggestedCategory || opt.text === aiSuggestedCategory) {
                sel.value = opt.value;
                sel.style.transition = 'border-color 0.3s';
                sel.style.borderColor = '#28a745';
                setTimeout(() => sel.style.borderColor = '', 1500);
                break;
            }
        }

        // Fill item name — only if the field is currently empty
        if (aiSuggestedName) {
            const nameField = document.getElementById('itemName');
            if (!nameField.value.trim()) {
                // Capitalise first letter of each word for a clean name
                nameField.value = aiSuggestedName
                    .split(',')[0]          // take first label before any comma
                    .split(' ')
                    .map(w => w.charAt(0).toUpperCase() + w.slice(1))
                    .join(' ');
                nameField.style.transition  = 'border-color 0.3s';
                nameField.style.borderColor = '#28a745';
                setTimeout(() => nameField.style.borderColor = '', 1500);
            }
        }

        document.getElementById('aiSuggestionCard').style.display = 'none';
    }

    // ── DISMISS SUGGESTION ────────────────────────────────────────────────────
    function dismissAISuggestion() {
        document.getElementById('aiSuggestionCard').style.display = 'none';
        aiSuggestedCategory = null;
        aiSuggestedName     = null;
    }

    // ── ENABLE SCAN BUTTON WHEN IMAGE IS LOADED ───────────────────────────────
    document.getElementById('itemImage').addEventListener('change', () => {
        // Re-enable scan button when new image is picked (model may already be ready)
        setTimeout(() => {
            if (mobileNetModel) {
                document.getElementById('aiScanBtn').disabled = false;
            }
        }, 300);
        // Hide old suggestion
        document.getElementById('aiSuggestionCard').style.display = 'none';
    });

    // Init Lucide icons
    document.addEventListener('DOMContentLoaded', () => lucide.createIcons());
    </script>


    <script>
    // ── CAMERA / TAKE PHOTO ───────────────────────────────────────────────────
    let cameraStream   = null;
    let capturedBlob   = null;
    let autoScanAfter  = false; // set true when "Take Photo & Scan" triggers this

    function openCamera(autoScan = false) {
        autoScanAfter = autoScan;
        const modal = document.getElementById('cameraModal');
        const video = document.getElementById('cameraVideo');
        const err   = document.getElementById('cameraError');
        err.style.display = 'none';
        document.getElementById('captureBtn').style.display  = 'flex';
        document.getElementById('retakeBtn').style.display   = 'none';
        document.getElementById('useCaptureBtn').style.display = 'none';
        modal.classList.add('open');
        lucide.createIcons();

        navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' }, audio: false })
            .then(stream => {
                cameraStream  = stream;
                video.srcObject = stream;
            })
            .catch(e => {
                err.style.display = 'block';
                err.textContent   = 'Camera access denied or unavailable. Please allow camera permission and try again.';
                console.error('Camera error:', e);
            });
    }

    function closeCamera() {
        if (cameraStream) { cameraStream.getTracks().forEach(t => t.stop()); cameraStream = null; }
        document.getElementById('cameraModal').classList.remove('open');
        document.getElementById('cameraVideo').srcObject = null;
        autoScanAfter = false;
    }

    function capturePhoto() {
        const video  = document.getElementById('cameraVideo');
        const canvas = document.getElementById('cameraCanvas');
        canvas.width  = video.videoWidth  || 640;
        canvas.height = video.videoHeight || 480;
        canvas.getContext('2d').drawImage(video, 0, 0, canvas.width, canvas.height);

        // Show retake / use buttons
        document.getElementById('captureBtn').style.display    = 'none';
        document.getElementById('retakeBtn').style.display     = 'flex';
        document.getElementById('useCaptureBtn').style.display = 'flex';

        // Freeze video by stopping stream
        if (cameraStream) { cameraStream.getTracks().forEach(t => t.stop()); cameraStream = null; }

        // Store blob
        canvas.toBlob(blob => { capturedBlob = blob; }, 'image/jpeg', 0.92);
        lucide.createIcons();
    }

    function retakePhoto() {
        capturedBlob = null;
        document.getElementById('captureBtn').style.display    = 'flex';
        document.getElementById('retakeBtn').style.display     = 'none';
        document.getElementById('useCaptureBtn').style.display = 'none';
        // Restart stream
        navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' }, audio: false })
            .then(stream => {
                cameraStream = stream;
                document.getElementById('cameraVideo').srcObject = stream;
            });
        lucide.createIcons();
    }

    function useCapture() {
        if (!capturedBlob) return;
        const canvas  = document.getElementById('cameraCanvas');
        const preview = document.getElementById('previewImage');
        const imgPrev = document.getElementById('imagePreview');

        // Show preview
        const url       = URL.createObjectURL(capturedBlob);
        preview.src     = url;
        imgPrev.style.display = 'block';

        // Inject into the file input as a real File so it submits with the form
        const file = new File([capturedBlob], 'camera-photo.jpg', { type: 'image/jpeg' });
        const dt   = new DataTransfer();
        dt.items.add(file);
        document.getElementById('itemImage').files = dt.files;

        closeCamera();

        // Enable scan button
        if (mobileNetModel) document.getElementById('aiScanBtn').disabled = false;

        // Auto-scan if triggered by "Take Photo & Scan"
        if (autoScanAfter) {
            setTimeout(() => runAIScan(), 400);
        }
    }

    // "Take Photo & Scan" — opens camera then auto-runs scan after capture
    function openCameraAndScan() {
        openCamera(true);
    }

    // Close modal if clicking the dark backdrop
    document.getElementById('cameraModal').addEventListener('click', function(e) {
        if (e.target === this) closeCamera();
    });
    </script>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // ── FLOOR SELECTOR ────────────────────────────────────────────────
        const floorInput = document.getElementById('pinFloor');

        window.setFloor = function(val) {
            floorInput.value = val;
            ['floorLbl0','floorLbl1','floorLbl2'].forEach(id => {
                document.getElementById(id).classList.remove('active-floor');
            });
            const idx = val === '' ? 0 : val === '1' ? 1 : 2;
            document.getElementById('floorLbl' + idx).classList.add('active-floor');
        };

        // ── LEAFLET PIN PICKER ────────────────────────────────────────────
        // Centred on Old Mill High School, 600 Patriot Ln, Millersville MD
        const SCHOOL_LAT = 39.1232, SCHOOL_LNG = -76.6286;

        const map = L.map('map-picker', { zoomControl: true }).setView([SCHOOL_LAT, SCHOOL_LNG], 18);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors',
            maxZoom: 21
        }).addTo(map);

        // Custom blue marker
        const pinIcon = L.divIcon({
            className: '',
            html: `<div style="width:22px;height:22px;background:linear-gradient(135deg,#0066cc,#cc0000);
                   border-radius:50% 50% 50% 0;transform:rotate(-45deg);border:2px solid white;
                   box-shadow:0 2px 8px rgba(0,0,0,0.3)"></div>`,
            iconSize: [22, 22],
            iconAnchor: [11, 22]
        });

        let marker = null;
        const latInput  = document.getElementById('pinLat');
        const lngInput  = document.getElementById('pinLng');
        const pinNote   = document.getElementById('mapPinNote');
        const mapEl     = document.getElementById('map-picker');

        map.on('click', function(e) {
            const { lat, lng } = e.latlng;
            latInput.value = lat.toFixed(7);
            lngInput.value = lng.toFixed(7);

            if (marker) { marker.setLatLng(e.latlng); }
            else { marker = L.marker(e.latlng, { icon: pinIcon, draggable: true }).addTo(map); }

            marker.on('dragend', function() {
                const p = marker.getLatLng();
                latInput.value = p.lat.toFixed(7);
                lngInput.value = p.lng.toFixed(7);
                pinNote.textContent = `📍 Pinned at ${p.lat.toFixed(5)}, ${p.lng.toFixed(5)} — drag to adjust`;
            });

            mapEl.classList.add('has-pin');
            pinNote.textContent = `📍 Pinned at ${lat.toFixed(5)}, ${lng.toFixed(5)} — drag to adjust`;
            pinNote.classList.add('selected');
        });
    </script>
