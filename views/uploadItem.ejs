    </button>
</nav>

<div class="mobile-menu" id="mobileMenu">
    <a href="/">Home</a>
    <a href="/uploadItem">Submit Item</a>
    <a href="/browse">Browse Items</a>
    <a href="/claim">Claim Item</a>
    <a href="/account" class="nav-auth">My Account</a>
    <a href="/register" class="nav-auth">Register</a>
    <a href="/login" class="nav-auth">Login</a>
    <a href="/admin/login" class="nav-auth">Admin</a>
</div>

    <main>
        <div class="upload-container">
            <div class="upload-header">
                <h1>Submit a Found Item</h1>
                <p>Help us return lost items to their owners by providing details about what you found</p>
            </div>

            <div id="statusMessage" class="status-message"></div>

            <div class="upload-card">
                <form id="uploadForm" enctype="multipart/form-data">
                    <!-- Section 1: Item Details -->
                    <div class="form-section">
                        <h3>Item Details</h3>

                        <div class="form-group">
                            <label for="itemName">Item Name <span class="required">*</span></label>
                            <input type="text" id="itemName" name="itemName" required maxlength="255"
                                   placeholder="e.g., Black iPhone 14 Pro Max">
                        </div>

                        <div class="form-group">
                            <label for="description">Description</label>
                            <textarea id="description" name="description" rows="4" maxlength="1000"
                                      placeholder="Describe the item in detail. Include color, brand, condition, distinctive features, etc."></textarea>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="category">Category</label>
                                <select id="category" name="category"><option value="">Select a category</option></select>
                            </div>

                            <div class="form-group">
                                <label for="dateFound">Date Found <span class="required">*</span></label>
                                <input type="date" id="dateFound" name="dateFound" required>
                            </div>
                        </div>
                    </div>

                    <!-- Section 2: Location Information -->
                    <div class="form-section">
                        <h3>Location & Contact</h3>

                        <div class="form-group">
                            <label for="location">Where was it found? <span class="required">*</span></label>
                            <input type="text" id="location" name="location" required maxlength="255"
                                   placeholder="e.g., Library building, 2nd floor, near entrance">

                            <!-- Floor selector -->
                            <div style="margin-top:16px;margin-bottom:14px;">
                                <label style="font-weight:600;color:#333;font-size:0.95em;display:block;margin-bottom:8px;">
                                    Which floor? <span style="color:#999;font-weight:400;">(optional)</span>
                                </label>
                                <div style="display:flex;gap:10px;flex-wrap:wrap;">
                                    <label class="floor-radio-label active-floor" id="floorLbl0">
                                        <input type="radio" name="pinFloorRadio" value="" checked onchange="setFloor('')"> Not sure
                                    </label>
                                    <label class="floor-radio-label" id="floorLbl1">
                                        <input type="radio" name="pinFloorRadio" value="1" onchange="setFloor('1')"> Floor 1
                                    </label>
                                    <label class="floor-radio-label" id="floorLbl2">
                                        <input type="radio" name="pinFloorRadio" value="2" onchange="setFloor('2')"> Floor 2
                                    </label>
                                </div>
                            </div>

                            <!-- Leaflet pin picker -->
                            <label style="font-weight:600;color:#333;font-size:0.95em;display:block;margin-bottom:6px;">
                                Pin the exact spot <span style="color:#999;font-weight:400;">(optional)</span>
                            </label>
                            <div id="map-picker"></div>
                            <p class="map-pin-note" id="mapPinNote">Click anywhere on the map to drop a pin</p>

                            <!-- Hidden fields submitted with form -->
                            <input type="hidden" id="pinLat"   name="pinLat"   value="">
                            <input type="hidden" id="pinLng"   name="pinLng"   value="">
                            <input type="hidden" id="pinFloor" name="pinFloor" value="">
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="contactName">Your Name <span class="required">*</span></label>
                                <input type="text" id="contactName" name="contactName" required maxlength="255"
                                       placeholder="Your full name">
                            </div>

                            <div class="form-group">
                                <label for="contactNumber">Phone Number <span class="required">*</span></label>
                                <input type="tel" id="contactNumber" name="contactNumber" required maxlength="20"
                                       placeholder="(555) 123-4567">
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="contactEmail">Email Address <span class="required">*</span></label>
                            <input type="email" id="contactEmail" name="contactEmail" required
                                   placeholder="your.email@example.com">
                        </div>
                    </div>

                    <!-- Section 3: Image Upload -->
                    <div class="form-section">
                        <h3>Item Photo (Optional)</h3>

                        <div class="form-info">
                            Upload a clear photo of the item. This greatly increases the chances of finding the owner.
                        </div>

                        <!-- Upload row: file upload + take photo -->
                        <div class="photo-input-row">
                            <div class="file-input-wrapper" style="flex:1;">
                                <label class="file-input-label">
                                    <input type="file" id="itemImage" name="itemImage" accept="image/*">
                                    <div>
                                        <div style="font-size:2em;margin-bottom:10px;"><i class="fa-solid fa-cloud-arrow-up" style="background:linear-gradient(135deg,#0066cc,#cc0000);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;"></i></div>
                                        <div style="font-weight:600;color:#0066cc;">Click to upload or drag and drop</div>
                                        <div style="font-size:0.9em;color:#999;margin-top:5px;">JPG, PNG, GIF up to 5MB</div>
                                    </div>
                                </label>
                            </div>

                            <div class="take-photo-btn-wrap">
                                <button type="button" id="takePhotoBtn" onclick="openCamera()">
                                    <i data-lucide="camera"></i>
                                    Take Photo
                                </button>
                                <div style="font-size:0.78em;color:#aaa;margin-top:6px;text-align:center;">Use your camera</div>
                            </div>
                        </div>

                        <!-- Camera modal -->
                        <div id="cameraModal">
                            <div id="cameraCard">
                                <div id="cameraHeader">
                                    <span id="cameraTitle"><i data-lucide="camera" style="width:16px;height:16px;vertical-align:middle;margin-right:6px;"></i>Take a Photo</span>
                                    <button id="cameraCloseBtn" onclick="closeCamera()" aria-label="Close">&#x2715;</button>
                                </div>
                                <video id="cameraVideo" autoplay playsinline muted></video>
                                <canvas id="cameraCanvas" style="display:none;"></canvas>
                                <div id="cameraActions">
                                    <button id="captureBtn" onclick="capturePhoto()">
                                        <i data-lucide="aperture"></i>
                                        Capture
                                    </button>
                                    <button id="retakeBtn" style="display:none;" onclick="retakePhoto()">
                                        <i data-lucide="rotate-ccw"></i>
                                        Retake
                                    </button>
                                    <button id="useCaptureBtn" style="display:none;" onclick="useCapture()">
                                        <i data-lucide="check"></i>
                                        Use Photo
                                    </button>
                                </div>
                                <div id="cameraError" style="display:none;color:#cc0000;font-size:0.85em;padding:10px;text-align:center;"></div>
                            </div>
                        </div>

                        <div id="imagePreview" class="image-preview">
                            <img id="previewImage" alt="Preview">
                        </div>

                        <!-- AI Scan + Take Photo & Scan buttons -->
                        <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-top:4px;">
                            <button type="button" id="aiScanBtn" disabled onclick="runAIScan()">
                                <i data-lucide="scan-search"></i>
                                Scan with AI
                            </button>
                            <button type="button" id="takeAndScanBtn" onclick="openCameraAndScan()">
                                <i data-lucide="camera"></i>
                                Take Photo &amp; Scan
                            </button>
                            <span id="aiStatusBadge">
                                <span id="aiStatusDot" class="loading"></span>
                                <span id="aiStatusText">Loading AI model...</span>
                            </span>
                        </div>

                        <!-- AI Suggestion Card -->
                        <div id="aiSuggestionCard">
                            <div class="ai-label">
                                <i data-lucide="sparkles"></i>
                                AI Detection Result
                            </div>
                            <div id="aiDetectedItem">—</div>
                            <div id="aiDetectedCategory">Suggested category: —</div>
                            <div class="ai-actions">
                                <button class="ai-btn-yes" onclick="acceptAISuggestion()">
                                    ✓ Yes, use this category
                                </button>
                                <button class="ai-btn-no" onclick="dismissAISuggestion()">
                                    ✗ No, I'll pick manually
                                </button>
                            </div>
                            <div id="aiRawPredictions"></div>
                        </div>
                    </div>

                    <!-- Submit Actions -->
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary" id="submitBtn">
                            Submit Found Item
                        </button>
                        <button type="reset" class="btn btn-secondary">
                            Clear Form
                        </button>
                    </div>

                    <!-- Loading Indicator -->
                    <div id="loadingIndicator" class="loading-indicator">
                        <div class="spinner"></div>
                        <p>Submitting your item... Please wait</p>
                    </div>

                </form>
            </div>
        </div>
    </main>

