    <main>
        <div class="contact-container">
            <div class="contact-header">
                <h1>Contact Us</h1>
                <p>Have questions? We're here to help</p>
            </div>

            <div class="contact-grid">
                <!-- Contact Information -->
                <div class="contact-info">
                    <h3>📍 Get in Touch</h3>
                    
                    <div class="contact-item">
                        <strong>Email</strong>
                        <a href="/cdn-cgi/l/email-protection#a0d3d5d0d0cfd2d4e0cccfd3d4c2d5d4c6cfd5cec48ec5c4d5"><span class="__cf_email__" data-cfemail="7d0e080d0d120f093d11120e091f08091b1208131953181908">[email&#160;protected]</span></a>
                    </div>

                    <div class="contact-item">
                        <strong>Phone</strong>
                        (555) 123-4567
                    </div>

                    <div class="contact-item">
                        <strong>Address</strong>
                        Campus Lost & Found Office<br>
                        Student Center, Room 101<br>
                        Campus University
                    </div>

                    <div class="contact-item">
                        <strong>Office Hours</strong>
                        Monday - Friday: 9:00 AM - 5:00 PM<br>
                        Saturday: 10:00 AM - 2:00 PM<br>
                        Sunday: Closed
                    </div>

                    <div class="contact-item">
                        <strong>Response Time</strong>
                        We typically respond within 24 hours
                    </div>
                </div>

                <!-- Contact Form -->
                <div class="contact-form">
                    <h2>Send us a Message</h2>
                    <div id="statusMessage" class="status-message"></div>

                    <form id="contactForm">
                        <div class="form-group">
                            <label for="name">Your Name <span class="required">*</span></label>
                            <input type="text" id="name" name="name" required maxlength="255" placeholder="John Doe">
                        </div>

                        <div class="form-group">
                            <label for="email">Email <span class="required">*</span></label>
                            <input type="email" id="email" name="email" required placeholder="your.email@example.com">
                        </div>

                        <div class="form-group">
                            <label for="subject">Subject <span class="required">*</span></label>
                            <input type="text" id="subject" name="subject" required maxlength="255" placeholder="What is this about?">
                        </div>

                        <div class="form-group">
                            <label for="message">Message <span class="required">*</span></label>
                            <textarea id="message" name="message" rows="5" required maxlength="2000" placeholder="Tell us your message..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary" id="sendBtn" style="width: 100%;">
                            Send Message
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </main>

