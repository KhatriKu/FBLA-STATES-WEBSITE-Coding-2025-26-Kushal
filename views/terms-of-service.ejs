            background-color: #f9f9f9;
            border-left: 5px solid #0066cc;
            padding: 25px;
            margin: 30px 0;
            border-radius: 5px;
        }

        .table-of-contents h2 {
            color: #0066cc;
            margin-top: 0;
        }

        .table-of-contents ul {
            list-style-type: none;
            padding-left: 0;
        }

        .table-of-contents li {
            margin: 12px 0;
        }

        .table-of-contents a {
            color: #0066cc;
            text-decoration: none;
            font-weight: 500;
        }

        .table-of-contents a:hover {
            text-decoration: underline;
            color: #cc0000;
        }

        .terms-section {
            margin: 40px 0;
            padding: 25px;
            background-color: #ffffff;
            border-radius: 5px;
            border-left: 4px solid #0066cc;
        }

        .terms-section h2 {
            color: #0066cc;
            font-size: 1.8em;
            margin-top: 0;
            padding-bottom: 15px;
            border-bottom: 2px solid #cc0000;
        }

        .terms-section h3 {
            color: #0066cc;
            font-size: 1.3em;
            margin-top: 25px;
            margin-bottom: 15px;
        }

        .terms-section ul {
            margin-left: 20px;
        }

        .terms-section li {
            margin-bottom: 12px;
            padding-left: 10px;
        }

        .contact-info {
            background: linear-gradient(135deg, rgba(0, 102, 204, 0.1) 0%, rgba(204, 0, 0, 0.1) 100%);
            padding: 20px;
            border-radius: 5px;
            margin-top: 20px;
        }

        .contact-info h3 {
            color: #0066cc;
            margin-bottom: 15px;
        }

        .contact-info a {
            color: #0066cc;
            text-decoration: none;
        }

        .contact-info a:hover {
            text-decoration: underline;
        }

        @media (max-width: 768px) {
            .terms-container {
                padding: 20px;
            }

            .terms-header h1 {
                font-size: 1.8em;
            }

            .terms-section {
                padding: 15px;
            }

            .terms-section h2 {
                font-size: 1.3em;
            }
        }
