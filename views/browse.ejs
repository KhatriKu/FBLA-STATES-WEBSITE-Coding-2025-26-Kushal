    <nav id="nav-bar" class="transparent">
        <div class="nav-left">
            <a href="/" class="nav-logo">
                <img src="/images/Home-logo.png" alt="Lost But Found" width="48" height="48">
            </a>
            <a href="/uploadItem">Submit Item</a>
            <a href="/browse">Browse Items</a>
            <a href="/claim">Claim Item</a>
        </div>
        <div class="nav-right">
            <a href="/account" class="nav-auth">My Account</a>
            <a href="/register" class="nav-auth">Register</a>
            <a href="/login" class="nav-auth">Login</a>
            <a href="/admin/login" class="nav-auth">Admin</a>
        </div>
        <button class="hamburger-menu" id="hamburgerBtn" aria-label="Toggle menu">
            <span></span><span></span><span></span>
        </button>
    </nav>

    <div class="mobile-menu" id="mobileMenu">
        <a href="/">Home</a>
        <a href="/uploadItem">Submit Item</a>
        <a href="/browse">Browse Items</a>
        <a href="/claim">Claim Item</a>
        <a href="/account" class="nav-auth">My Account</a>
        <a href="/register" class="nav-auth">Register</a>
        <a href="/login" class="nav-auth">Login</a>
        <a href="/admin/login" class="nav-auth">Admin</a>
    </div>

    <main>
        <div class="browse-container">
            <div class="browse-header">
                <h1>Browse Found Items</h1>
                <p>Search for your lost belongings — click a card to pin it</p>
            </div>

            <!-- Filters -->
            <div class="browse-filters">
                <div class="filter-grid">
                    <input type="text" id="searchInput" placeholder="Search by name or description...">
                    <select id="categoryFilter"><option value="">All Categories</option></select>
                    <select id="statusFilter">
                        <option value="">All Status</option>
                        <option value="active">Available</option>
                        <option value="pending">Pending</option>
                        <option value="claimed">Claimed</option>
                    </select>
                    <input type="date" id="dateFilter">
                </div>
                <div class="filter-actions">
                    <button class="btn btn-primary" onclick="applyFilters()">
                        <i class="fa-solid fa-magnifying-glass"></i> Search
                    </button>
                    <button class="btn btn-secondary" onclick="resetFilters()">Reset</button>
                </div>
            </div>

            <!-- View toggle + count -->
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; flex-wrap:wrap; gap:10px;">
                <div class="results-info">Showing <strong id="itemCount">0</strong> items</div>
                <div class="view-toggle">
                    <button class="view-btn active" id="btnCork" onclick="setView('cork')">
                        <i class="fa-solid fa-thumbtack"></i> Cork Board
                    </button>
                    <button class="view-btn" id="btnList" onclick="setView('list')">
                        <i class="fa-solid fa-list"></i> List
                    </button>
                </div>
            </div>

            <!-- Cork Board -->
            <div id="corkBoard"></div>

            <!-- List View -->
            <div id="listView"></div>

            <div id="noItems">
                <i class="fa-solid fa-box-open" style="font-size:2.5em;color:#ddd;display:block;margin-bottom:12px;"></i>
                <p style="font-size:1.1em;">No items found. Try adjusting your filters.</p>
            </div>
        </div>
    </main>

    <!-- Detail Modal -->
    <div id="detailOverlay">
        <div id="detailModal">
            <button class="modal-close" onclick="closeDetail()" aria-label="Close">
                <i class="fa-solid fa-xmark"></i>
            </button>
            <div id="modalContent"></div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-content">
            <div class="footer-column">
                <h3>Lost But Found</h3>
                <p class="footer-description">Helping reunite people with their lost belongings through a simple and secure platform.</p>
            </div>
            <div class="footer-column">
                <h3>Quick Links</h3>
                <ul class="footer-links">
                    <li><a href="/">Home</a></li>
                    <li><a href="/browse">Browse Items</a></li>
                    <li><a href="/upload">Submit Item</a></li>
                    <li><a href="/claim">Claim Item</a></li>
                </ul>
            </div>
            <div class="footer-column">
                <h3>User</h3>
                <ul class="footer-links">
                    <li><a href="/register">Register</a></li>
                    <li><a href="/login">Login</a></li>
                    <li><a href="/faq">FAQ</a></li>
                    <li><a href="/contact">Contact Us</a></li>
                </ul>
            </div>
            <div class="footer-column">
                <h3>Admin</h3>
                <ul class="footer-links">
                    <li><a href="/admin/login">Admin Login</a></li>
                    <li><a href="/faq">Support</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="footer-copyright">&copy; 2025 Lost But Found. All rights reserved.</div>
            <div class="footer-legal">
                <div class="footer-legal-text">
                    By using this platform, you agree to our <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>
                </div>
            </div>
            <div class="footer-bottom-links">
                <a href="#">Terms</a><span class="divider">|</span>
                <a href="#">Privacy</a><span class="divider">|</span>
                <a href="#">Contact</a>
            </div>
        </div>
    </footer>

    <script>
    // ── STATE ──────────────────────────────────────────────────────────────────
    let allItems     = [];
    let displayedItems = [];
    let currentView  = 'cork';
    let cardStates   = {};  // { itemId: { pinned, x, y, rot, vx, vy, animId } }
    let rafId        = null;

    const CARD_W = 164, CARD_H = 178;

    // ── CATEGORY LOADER ────────────────────────────────────────────────────────
    async function loadCategories() {
        try {
            const res  = await fetch('/api/categories');
            const data = await res.json();
            if (data.success) {
                const sel = document.getElementById('categoryFilter');
                data.categories.forEach(cat => {
                    const opt = document.createElement('option');
                    opt.value = cat.name; opt.textContent = cat.name;
                    sel.appendChild(opt);
                });
            }
        } catch(e) {}
    }

    // ── ITEMS LOADER ───────────────────────────────────────────────────────────
    async function loadItems() {
        try {
            const res  = await fetch('/api/items');
            const data = await res.json();
            if (data.success) {
                allItems = data.items || [];
                displayItems(allItems);
            }
        } catch(e) { console.error('Load items error:', e); }
    }

    // ── DISPLAY DISPATCHER ─────────────────────────────────────────────────────
    function displayItems(items) {
        displayedItems = items;
        document.getElementById('itemCount').textContent = items.length;
        document.getElementById('noItems').style.display = items.length === 0 ? 'block' : 'none';
        if (currentView === 'cork') buildCorkBoard(items);
        else buildListView(items);
    }

    function setView(v) {
        currentView = v;
        document.getElementById('btnCork').classList.toggle('active', v === 'cork');
        document.getElementById('btnList').classList.toggle('active', v === 'list');
        document.getElementById('corkBoard').style.display = v === 'cork' ? 'block' : 'none';
        document.getElementById('listView').style.display  = v === 'list'  ? 'block' : 'none';
        if (v === 'cork') buildCorkBoard(displayedItems);
        else              buildListView(displayedItems);
    }

    // ══════════════════════════════════════════════════════════════════════════
    //  CORK BOARD
    // ══════════════════════════════════════════════════════════════════════════

    function buildCorkBoard(items) {
        cancelAnimationFrame(rafId);
        cardStates = {};
        const board = document.getElementById('corkBoard');
        board.innerHTML = '';
        if (!items.length) return;

        const bw = board.clientWidth  || 900;
        const bh = board.clientHeight || 680;

        items.forEach((item, idx) => {
            // Initial position — scatter across the board with margin
            const margin = 20;
            const x = margin + Math.random() * (bw - CARD_W - margin * 2);
            const y = margin + Math.random() * (bh - CARD_H - margin * 2);
            const rot = (Math.random() - 0.5) * 18; // -9 to +9 degrees
            const speed = 0.4 + Math.random() * 0.5;
            const angle = Math.random() * Math.PI * 2;

            cardStates[item.id] = {
                pinned: false,
                x, y, rot,
                vx: Math.cos(angle) * speed,
                vy: Math.sin(angle) * speed,
                targetRot: rot,
                wobbleT: Math.random() * Math.PI * 2  // wobble phase offset
            };

            // Build card element
            const el = document.createElement('div');
            el.className = 'cork-card';
            el.id = 'card-' + item.id;
            el.dataset.id = item.id;
            el.style.left = x + 'px';
            el.style.top  = y + 'px';
            el.style.transform = `rotate(${rot}deg)`;
            el.style.zIndex = 2 + idx;

            const statusClass = item.status || 'active';
            el.innerHTML = `
                <div class="push-pin" id="pin-${item.id}">
                    <div class="pin-head"></div>
                    <div class="pin-needle"></div>
                </div>
                <div class="card-paper">
                    ${item.imageUrl
                        ? `<img class="card-img" src="${item.imageUrl}" alt="${item.name}" draggable="false">`
                        : `<div class="card-no-img"><i class="fa-solid fa-box-open"></i></div>`}
                    <div class="card-info">
                        <div class="card-name">${item.name}</div>
                        <div class="card-cat">
                            <span class="card-status-dot ${statusClass}"></span>
                            ${item.category || 'Other'}
                        </div>
                    </div>
                </div>`;

            el.addEventListener('click', () => onCardClick(item.id, item));
            board.appendChild(el);
        });

        // Start animation loop
        animateBoard();
    }

    // ── ANIMATION LOOP ─────────────────────────────────────────────────────────
    function animateBoard() {
        const board = document.getElementById('corkBoard');
        if (!board) return;
        const bw = board.clientWidth;
        const bh = board.clientHeight;

        Object.entries(cardStates).forEach(([id, s]) => {
            if (s.pinned) return;
            const el = document.getElementById('card-' + id);
            if (!el) return;

            // Move
            s.x += s.vx;
            s.y += s.vy;

            // Bounce off walls
            if (s.x <= 0)            { s.x = 0;            s.vx =  Math.abs(s.vx); }
            if (s.x >= bw - CARD_W)  { s.x = bw - CARD_W;  s.vx = -Math.abs(s.vx); }
            if (s.y <= 0)            { s.y = 0;             s.vy =  Math.abs(s.vy); }
            if (s.y >= bh - CARD_H)  { s.y = bh - CARD_H;  s.vy = -Math.abs(s.vy); }

            // Gentle wobble rotation
            s.wobbleT += 0.018;
            const rot = s.rot + Math.sin(s.wobbleT) * 2.5;

            el.style.left      = s.x + 'px';
            el.style.top       = s.y + 'px';
            el.style.transform = `rotate(${rot}deg)`;
        });

        rafId = requestAnimationFrame(animateBoard);
    }

    // ── CARD CLICK → PIN ANIMATION ────────────────────────────────────────────
    function onCardClick(id, item) {
        const state = cardStates[id];
        if (!state) return;

        if (state.pinned) {
            // Already pinned — open detail modal directly
            openDetail(item);
            return;
        }

        // Stop this card
        state.pinned = true;
        state.vx = 0; state.vy = 0;

        const el  = document.getElementById('card-' + id);
        const pin = document.getElementById('pin-' + id);

        // Snap to a clean slight tilt
        const finalRot = (Math.random() - 0.5) * 8;
        el.style.transition = 'transform 0.3s ease, box-shadow 0.3s';
        el.style.transform  = `rotate(${finalRot}deg)`;
        el.style.zIndex     = 50;
        el.classList.add('pinned');

        // Pin drop animation
        pin.classList.add('dropping');
        pin.addEventListener('animationend', () => {
            pin.classList.remove('dropping');
            pin.classList.add('pinned');
        }, { once: true });

        // After pin settles, show "View Details" button on card
        setTimeout(() => {
            const info = el.querySelector('.card-info');
            if (info && !info.querySelector('.card-view-btn')) {
                const btn = document.createElement('button');
                btn.className   = 'card-view-btn';
                btn.textContent = 'View Details';
                btn.style.cssText = `
                    width:100%; margin-top:6px; padding:5px 8px;
                    background: linear-gradient(135deg,#0066cc,#cc0000);
                    color:white; border:none; border-radius:4px;
                    font-size:0.72em; font-weight:700; cursor:pointer;
                    font-family:inherit;`;
                btn.onclick = (e) => { e.stopPropagation(); openDetail(item); };
                info.appendChild(btn);
            }
            el.style.transition = '';
        }, 500);
    }

    // ══════════════════════════════════════════════════════════════════════════
    //  DETAIL MODAL
    // ══════════════════════════════════════════════════════════════════════════

    function openDetail(item) {
        const statusLabels = { active: 'Available', claimed: 'Claimed', pending: 'Pending Review', returned: 'Returned' };
        const statusLabel  = statusLabels[item.status] || item.status || 'Unknown';
        const dateStr      = item.dateFound ? new Date(item.dateFound).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' }) : 'Unknown';
        const statusBar    = item.status === 'active' ? 'active' : item.status === 'claimed' ? 'claimed' : 'pending';

        document.getElementById('modalContent').innerHTML = `
            ${item.imageUrl
                ? `<img class="modal-img" src="${item.imageUrl}" alt="${item.name}">`
                : `<div class="modal-no-img"><i class="fa-solid fa-box-open"></i></div>`}
            <div class="modal-body">
                <div class="modal-category">
                    <i class="fa-solid fa-tag" style="margin-right:5px;"></i>${item.category || 'Other'}
                </div>
                <div class="modal-title">${item.name}</div>

                <div class="modal-status-bar ${statusBar}">
                    <i class="fa-solid fa-circle-dot"></i>
                    <strong>${statusLabel}</strong>
                    ${item.status === 'active' ? '— This item is available to claim' : ''}
                </div>

                <div class="modal-meta">
                    <div class="modal-meta-item">
                        <span class="modal-meta-label"><i class="fa-solid fa-location-dot"></i> Location Found</span>
                        <span class="modal-meta-value">${item.location || 'Not specified'}</span>
                    </div>
                    <div class="modal-meta-item">
                        <span class="modal-meta-label"><i class="fa-solid fa-calendar"></i> Date Found</span>
                        <span class="modal-meta-value">${dateStr}</span>
                    </div>
                    <div class="modal-meta-item">
                        <span class="modal-meta-label"><i class="fa-solid fa-user"></i> Found By</span>
                        <span class="modal-meta-value">${item.contactName || 'Anonymous'}</span>
                    </div>
                    <div class="modal-meta-item">
                        <span class="modal-meta-label"><i class="fa-solid fa-envelope"></i> Contact</span>
                        <span class="modal-meta-value">${item.contactEmail || item.contactNumber || 'N/A'}</span>
                    </div>
                </div>

                ${item.description ? `
                <div class="modal-desc">
                    <strong style="display:block;margin-bottom:6px;font-size:0.8em;text-transform:uppercase;letter-spacing:.05em;color:#999;">Description</strong>
                    ${item.description}
                </div>` : ''}

                <div class="modal-actions">
                    ${item.status === 'active'
                        ? `<a href="/claim?itemId=${item.id}" class="btn btn-primary">
                               <i class="fa-solid fa-hand-point-up"></i> Claim This Item
                           </a>`
                        : `<button class="btn btn-secondary" disabled>Not Available</button>`}
                    <button class="btn btn-secondary" onclick="closeDetail()">
                        <i class="fa-solid fa-arrow-left"></i> Back
                    </button>
                </div>
            </div>`;

        document.getElementById('detailOverlay').classList.add('open');
        document.body.style.overflow = 'hidden';
    }

    function closeDetail() {
        document.getElementById('detailOverlay').classList.remove('open');
        document.body.style.overflow = '';
    }

    // Close on backdrop click
    document.getElementById('detailOverlay').addEventListener('click', function(e) {
        if (e.target === this) closeDetail();
    });

    // Close on Escape
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDetail(); });

    // ══════════════════════════════════════════════════════════════════════════
    //  LIST VIEW
    // ══════════════════════════════════════════════════════════════════════════

    function buildListView(items) {
        const container = document.getElementById('listView');
        if (!items.length) { container.innerHTML = ''; return; }
        container.innerHTML = items.map(item => `
            <div class="list-item-card" onclick="openDetail(allItems.find(i=>i.id===${item.id}))">
                ${item.imageUrl
                    ? `<img class="list-item-img" src="${item.imageUrl}" alt="${item.name}">`
                    : `<div class="list-item-noimg"><i class="fa-solid fa-box-open"></i></div>`}
                <div class="list-item-info">
                    <div class="list-item-name">${item.name}</div>
                    <div class="list-item-cat">${item.category || 'Other'}</div>
                    <div class="list-item-meta">
                        <span><i class="fa-solid fa-location-dot"></i> ${item.location || 'Not specified'}</span>
                        <span><i class="fa-solid fa-calendar"></i> ${item.dateFound ? new Date(item.dateFound).toLocaleDateString() : 'Unknown'}</span>
                        <span><span class="card-status-dot ${item.status}" style="width:8px;height:8px;vertical-align:middle;display:inline-block;border-radius:50%;margin-right:3px;background:${item.status==='active'?'#28a745':item.status==='claimed'?'#f0a500':'#ccc'}"></span>${item.status || 'active'}</span>
                    </div>
                </div>
                <button class="btn btn-primary" style="padding:8px 16px;font-size:0.85em;align-self:center;">Details</button>
            </div>`).join('');
    }

    // ── FILTERS ────────────────────────────────────────────────────────────────
    function applyFilters() {
        const search   = document.getElementById('searchInput').value.toLowerCase();
        const category = document.getElementById('categoryFilter').value;
        const status   = document.getElementById('statusFilter').value;
        const date     = document.getElementById('dateFilter').value;
        const filtered = allItems.filter(item => {
            const ms = !search   || item.name.toLowerCase().includes(search) || (item.description||'').toLowerCase().includes(search);
            const mc = !category || item.category === category;
            const mx = !status   || item.status === status;
            const md = !date     || (item.dateFound && new Date(item.dateFound).toLocaleDateString() === new Date(date).toLocaleDateString());
            return ms && mc && mx && md;
        });
        displayItems(filtered);
    }

    function resetFilters() {
        ['searchInput','categoryFilter','statusFilter','dateFilter'].forEach(id => document.getElementById(id).value = '');
        displayItems(allItems);
    }

    // ── NAV ────────────────────────────────────────────────────────────────────
    window.addEventListener('scroll', () => {
        document.getElementById('nav-bar').classList.toggle('transparent', window.scrollY <= 50);
    });
    const hamburgerBtn = document.getElementById('hamburgerBtn');
    const mobileMenu   = document.getElementById('mobileMenu');
    if (hamburgerBtn) {
        hamburgerBtn.addEventListener('click', () => {
            hamburgerBtn.classList.toggle('active');
            mobileMenu.classList.toggle('active');
        });
        mobileMenu.querySelectorAll('a').forEach(l => l.addEventListener('click', () => {
            hamburgerBtn.classList.remove('active');
            mobileMenu.classList.remove('active');
        }));
    }

    // Filter listeners
    document.getElementById('searchInput').addEventListener('keyup',    applyFilters);
    document.getElementById('categoryFilter').addEventListener('change', applyFilters);
    document.getElementById('statusFilter').addEventListener('change',   applyFilters);

    // ── INIT ───────────────────────────────────────────────────────────────────
    loadCategories();
    loadItems();
    </script>
</body>
</html>